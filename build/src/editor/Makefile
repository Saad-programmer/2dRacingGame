	cd /home/alan/Games/2dCar/DustRacing2D/build && $(MAKE) $(MAKESILENT) -f src/editor/CMakeFiles/dustrac-editor.dir/build.make src/editor/CMakeFiles/dustrac-editor.dir/tracktile.cpp.o
.PHONY : tracktile.cpp.o

